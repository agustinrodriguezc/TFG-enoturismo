<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Mapa_Bibliografía_TFG</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;background:#f4f0e8;font-family:'Georgia',serif;color:#1a1814}
/* HEADER */
#hdr{position:fixed;top:0;left:0;right:0;z-index:60;background:#fff;border-bottom:1px solid #ddd8cc;box-shadow:0 1px 5px rgba(0,0,0,.07)}
#hdr-row1{padding:8px 18px;display:flex;align-items:center;gap:10px;flex-wrap:nowrap;white-space:nowrap;overflow:hidden}
#hdr-row2{padding:4px 22px 10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;border-top:1px solid #f0ece0}
#htitle{font-size:16px;letter-spacing:2px;text-transform:uppercase;color:#7a6a45;white-space:nowrap;font-style:italic;font-weight:700}
.hgrp{display:flex;gap:6px;align-items:center}
.hlab{font-size:12px;color:#9a8870;font-style:italic;white-space:nowrap}
.fb,.ifb{padding:4px 11px;border-radius:2px;font-size:12px;cursor:pointer;border:1px solid currentColor;font-family:'Georgia',serif;transition:all .15s;letter-spacing:.3px;background:transparent;white-space:nowrap}
.fb[data-h=all]{color:#4a4030;border-color:#a09070}.fb[data-h=H1]{color:#9a6a10}.fb[data-h=H2]{color:#146058}.fb[data-h=H3]{color:#6a3a98}.fb[data-h=H4]{color:#286040}
.fb[data-h=all].on{background:#4a4030;color:#fff}.fb[data-h=H1].on{background:#9a6a10;color:#fff}.fb[data-h=H2].on{background:#146058;color:#fff}.fb[data-h=H3].on{background:#6a3a98;color:#fff}.fb[data-h=H4].on{background:#286040;color:#fff}
.ifb[data-i=all]{color:#4a4030;border-color:#a09070}.ifb[data-i=ALTA]{color:#1a5fa8}.ifb[data-i=MEDIA]{color:#7a5a10}.ifb[data-i=BAJA]{color:#6a6060}
.ifb[data-i=all].on{background:#4a4030;color:#fff}.ifb[data-i=ALTA].on{background:#1a5fa8;color:#fff}.ifb[data-i=MEDIA].on{background:#7a5a10;color:#fff}.ifb[data-i=BAJA].on{background:#6a6060;color:#fff}
#search{padding:4px 9px;border:1px solid #c8bfa8;border-radius:2px;font-size:12px;font-family:'Georgia',serif;background:#faf8f3;color:#2a2018;outline:none;width:145px;flex-shrink:1;min-width:80px}
#search:focus{border-color:#9a6a10}
#cnt{font-size:12px;color:#9a8870;font-style:italic;white-space:nowrap}
#rev-info{display:flex;align-items:center;gap:8px;margin-left:10px}
#rev-cnt{font-size:12px;color:#2a8a4a;font-weight:600;white-space:nowrap}
#rev-bar{width:80px;height:7px;background:#e8e0d0;border-radius:3px;overflow:hidden}
#rev-fill{height:100%;background:#2a8a4a;border-radius:3px;transition:width .3s;width:0%}
#rev-reset{padding:4px 9px;border:1px solid #c8bfa8;border-radius:2px;font-size:12px;font-family:'Georgia',serif;background:#faf8f3;color:#6a5a40;cursor:pointer;white-space:nowrap}
#rev-reset:hover{background:#f0ece0}
/* CANVAS */
#cv{display:block;cursor:grab;position:fixed;top:0;left:0}
#cv:active{cursor:grabbing}
/* BLOCK PANEL — left */
#bpanel{position:fixed;top:0;left:-310px;width:290px;height:100%;background:#fff;border-right:1px solid #d0c8b0;box-shadow:3px 0 16px rgba(0,0,0,.1);z-index:75;display:flex;flex-direction:column;transition:left .28s cubic-bezier(.4,0,.2,1);overflow:hidden}
#bpanel.open{left:0}
#bp-head{padding:13px 14px 10px;border-bottom:1px solid #ece8e0;flex-shrink:0;position:relative}
#bp-title{font-size:12px;font-weight:700;margin-bottom:2px;padding-right:26px}
#bp-sub{font-size:9.5px;color:#7a6a50;font-style:italic}
#bp-body{flex:1;overflow-y:auto;padding:10px 14px 16px}
#bp-body::-webkit-scrollbar{width:3px}
#bp-body::-webkit-scrollbar-thumb{background:#d0c8b0;border-radius:2px}
.bclose{position:absolute;top:10px;right:10px;width:20px;height:20px;cursor:pointer;border:1px solid #d0c8b0;border-radius:2px;background:#faf8f3;display:flex;align-items:center;justify-content:center;font-size:10px;color:#6a5a40}
.bclose:hover{background:#f0ece0}
.bsec{font-size:7.5px;color:#9a8870;letter-spacing:1.8px;text-transform:uppercase;margin:10px 0 4px;font-style:italic;border-bottom:1px solid #ece8e0;padding-bottom:2px}
.bsec:first-child{margin-top:0}
.bval{font-size:10.5px;color:#2a2018;line-height:1.6}
.bsub{font-size:9.5px;color:#4a4030;margin:3px 0 2px;font-style:italic}
.bitem{font-size:9.5px;color:#3a3028;line-height:1.55;margin-bottom:3px;padding-left:8px;border-left:2px solid transparent}
.bitem.si{border-color:#2a8a4a}.bitem.mat{border-color:#c8920a}.bitem.pre{border-color:#c83030}
.bitem.reviewed{opacity:.45;text-decoration:line-through}
/* MODAL */
#overlay{position:fixed;inset:0;background:rgba(15,10,5,.55);z-index:80;display:none;align-items:center;justify-content:center}
#overlay.show{display:flex}
#modal{background:#fff;border:1px solid #d0c8b0;border-radius:3px;box-shadow:0 8px 40px rgba(0,0,0,.18);width:min(720px,93vw);max-height:88vh;display:flex;flex-direction:column;animation:mfade .18s ease}
@keyframes mfade{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
#m-head{padding:14px 16px 12px;border-bottom:1px solid #ece8e0;flex-shrink:0;position:relative}
#m-autor{font-size:15px;font-weight:700;color:#1a1814;line-height:1.3;padding-right:110px}
#m-sub{font-size:10px;color:#7a6a50;margin-top:3px;font-style:italic}
#m-head-actions{position:absolute;top:12px;right:14px;display:flex;align-items:center;gap:6px}
#m-rev-btn{padding:3px 10px;border-radius:2px;font-size:9.5px;font-family:'Georgia',serif;cursor:pointer;border:1px solid currentColor;transition:all .15s}
#m-close{width:22px;height:22px;cursor:pointer;border:1px solid #d0c8b0;border-radius:2px;background:#faf8f3;display:flex;align-items:center;justify-content:center;font-size:12px;color:#5a4a30}
#m-close:hover{background:#f0ece0}
#m-body{overflow-y:auto;padding:12px 16px 16px;display:grid;grid-template-columns:1fr 1fr;gap:0 18px}
#m-body::-webkit-scrollbar{width:4px}
#m-body::-webkit-scrollbar-thumb{background:#d0c8b0;border-radius:2px}
#m-full{grid-column:1/-1}
.ms{font-size:7.5px;color:#9a8870;letter-spacing:1.8px;text-transform:uppercase;margin:10px 0 3px;font-style:italic;border-bottom:1px solid #ece8e0;padding-bottom:2px}
.ms:first-child{margin-top:0}
.mv{font-size:11px;color:#2a2018;line-height:1.65}
.mref{font-size:10.5px;color:#3a3028;line-height:1.65;font-style:italic;background:#f8f5ee;border-left:3px solid #c8b890;padding:6px 10px;border-radius:0 2px 2px 0}
.mhips{display:flex;flex-wrap:wrap;gap:5px;margin-top:6px}
.mhip{padding:2px 9px;border-radius:2px;font-size:9px;font-weight:700;letter-spacing:.4px;border:1px solid currentColor}
.mver{display:inline-block;padding:4px 12px;border-radius:2px;font-size:10px;font-weight:600;margin-top:8px}
.i-alta{background:#e8f0fc;color:#1a5fa8;border:1px solid #a8c0e8}
.i-media{background:#fdf6e8;color:#7a5a10;border:1px solid #dfc880}
.i-baja{background:#f5f3f0;color:#5a5050;border:1px solid #c8c0b8}
/* LEGEND — draggable, starts bottom right */
#legend{position:fixed;top:58px;right:16px;z-index:62;background:#fff;border:1px solid #d0c8b0;border-radius:2px;padding:10px 13px;font-size:9.5px;line-height:2;box-shadow:0 2px 8px rgba(0,0,0,.07);cursor:move;user-select:none}
#legend-grip{font-size:8px;color:#b8b0a0;letter-spacing:2px;text-align:center;margin-bottom:4px;line-height:1}
.lsec{font-size:7.5px;color:#9a8870;letter-spacing:2px;text-transform:uppercase;margin-top:5px;line-height:1.5;font-style:italic}
.li{display:flex;align-items:center;gap:7px}.dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
/* ZOOM */
#zcont{position:fixed;bottom:16px;right:16px;z-index:60;display:flex;flex-direction:column;gap:4px}
.zb{width:28px;height:28px;background:#fff;border:1px solid #ccc8b8;color:#4a4030;font-size:14px;cursor:pointer;border-radius:2px;display:flex;align-items:center;justify-content:center}
.zb:hover{background:#f0ece0}
/* HOVER LABEL */
#hlabel{position:fixed;background:rgba(255,255,255,.93);border:1px solid #d0c8b0;border-radius:2px;padding:3px 9px;font-size:9.5px;color:#2a2018;pointer-events:none;display:none;z-index:65;box-shadow:0 2px 6px rgba(0,0,0,.08);font-style:italic}
/* HINT */
#hint{position:fixed;bottom:18px;left:50%;transform:translateX(-50%);font-size:8.5px;color:#b8b0a0;letter-spacing:1.5px;white-space:nowrap;z-index:60;font-style:italic;pointer-events:none}
/* EXPORT OVERLAY */
#exp-overlay{position:fixed;inset:0;background:rgba(15,10,5,.6);z-index:90;display:none;align-items:center;justify-content:center}
#exp-overlay.show{display:flex}
#exp-box{background:#fff;border:1px solid #d0c8b0;border-radius:3px;box-shadow:0 8px 40px rgba(0,0,0,.2);width:min(680px,92vw);display:flex;flex-direction:column;padding:18px 20px;gap:10px}
#exp-title{font-size:13px;font-weight:700;color:#2a2018}
#exp-sub{font-size:10.5px;color:#7a6a50;font-style:italic}
#exp-ta{width:100%;height:220px;font-family:monospace;font-size:11px;border:1px solid #c8bfa8;border-radius:2px;padding:8px;background:#f8f5ee;color:#1a1814;resize:vertical;outline:none}
#exp-actions{display:flex;gap:8px;justify-content:flex-end}
.exp-btn{padding:5px 14px;border-radius:2px;font-size:11px;font-family:'Georgia',serif;cursor:pointer;border:1px solid currentColor}
#exp-copy{color:#1a5fa8;border-color:#1a5fa8;background:#e8f0fc}
#exp-copy:hover{background:#d0e4f8}
#exp-close{color:#6a5a40;border-color:#c8bfa8;background:#faf8f3}
#exp-close:hover{background:#f0ece0}
/* EXPORT BUTTON in header */
</style>
</head>
<body>
<div id="hdr">
  <div id="hdr-row1">
    <span id="htitle">Mapa_Bibliografía_TFG</span>
    <div class="hgrp">
      <span class="hlab">Hipótesis:</span>
      <button class="fb on" data-h="all">Todos</button>
      <button class="fb" data-h="H1">H1</button>
      <button class="fb" data-h="H2">H2</button>
      <button class="fb" data-h="H3">H3</button>
      <button class="fb" data-h="H4">H4</button>
    </div>
    <div class="hgrp">
      <span class="hlab">Importancia:</span>
      <button class="ifb on" data-i="all">Todos</button>
      <button class="ifb" data-i="ALTA">★ Alta</button>
      <button class="ifb" data-i="MEDIA">◆ Media</button>
      <button class="ifb" data-i="BAJA">· Baja</button>
    </div>
    <div style="position:relative;display:flex;align-items:center;flex-shrink:1;min-width:80px">
      <input id="search" placeholder="Buscar autor, año, keyword…" autocomplete="off" style="width:145px;padding-right:22px">
      <span id="search-clear" onclick="clearSearch()" style="position:absolute;right:5px;cursor:pointer;font-size:11px;color:#9a8870;display:none;line-height:1;padding:2px">✕</span>
    </div>
    <span id="cnt">56 artículos</span>
    <div id="rev-info">
      <span id="rev-cnt">✓ 0 / 56 revisados</span>
      <div id="rev-bar"><div id="rev-fill"></div></div>
      <button id="rev-reset">↺ Resetear</button>
    </div>
  </div>
</div>
<canvas id="cv"></canvas>

<!-- EXPORT OVERLAY -->
<div id="exp-overlay" onclick="if(event.target===this)closeExport()">
  <div id="exp-box">
    <div id="exp-title">Exportar posiciones de artículos</div>
    <div id="exp-sub">Copia este bloque y pégalo donde se indica en el código (o envíaselo a Claude para aplicarlo).</div>
    <textarea id="exp-ta" readonly spellcheck="false"></textarea>
    <div id="exp-actions">
      <button class="exp-btn" id="exp-copy" onclick="copyExport()">Copiar al portapapeles</button>
      <button class="exp-btn" id="exp-close" onclick="closeExport()">Cerrar</button>
    </div>
  </div>
</div>

<!-- BLOCK SUMMARY PANEL -->
<div id="bpanel">
  <div id="bp-head">
    <div id="bp-title"></div>
    <div id="bp-sub"></div>
    <div class="bclose" onclick="closeBPanel()">✕</div>
  </div>
  <div id="bp-body"></div>
</div>

<!-- MODAL -->
<div id="overlay" onclick="handleOverlayClick(event)">
  <div id="modal">
    <div id="m-head">
      <div id="m-autor"></div>
      <div id="m-sub"></div>
      <div id="m-head-actions">
        <button id="m-rev-btn" onclick="toggleReviewedFromModal()"></button>
        <div id="m-close" onclick="closeModal()">✕</div>
      </div>
    </div>
    <div id="m-body"></div>
  </div>
</div>

<div id="legend">
  <div id="legend-grip">⋮⋮</div>
  <div class="lsec" style="margin-top:0">Importancia</div>
  <div class="li"><div class="dot" style="background:#1a5fa8"></div>★ Alta</div>
  <div class="li"><div class="dot" style="background:#7a5a10"></div>◆ Media</div>
  <div class="li"><div class="dot" style="background:#6a6060"></div>· Baja</div>
  <div class="lsec">Bloque</div>
  <div class="li"><div class="dot" style="background:#9a6a10"></div>H1 · Imagen</div>
  <div class="li"><div class="dot" style="background:#146058"></div>H2 · Confianza</div>
  <div class="li"><div class="dot" style="background:#6a3a98"></div>H3 · Moderación</div>
  <div class="li"><div class="dot" style="background:#286040"></div>H4 · Satisfacción</div>
  <div style="margin-top:5px;font-size:8.5px;color:#9a8870;font-style:italic">⚡ múltiples hipótesis</div>
  <div style="font-size:8.5px;color:#9a8870;font-style:italic">✓ = revisado &nbsp; clic = detalle</div>
</div>
<div id="zcont">
  <button class="zb" id="zi">+</button>
  <button class="zb" id="zo">−</button>
  <button class="zb" id="zr" style="font-size:10px">⟲</button>
</div>
<div id="hlabel"></div>
<div id="hint">óvalo del modelo · clic selecciona, arrastrar mueve &nbsp;&nbsp; círculo artículo · clic detalle &nbsp;&nbsp; scroll · zoom</div>

<script>
var BC={H1:'#9a6a10',H2:'#146058',H3:'#6a3a98',H4:'#286040',SP:'#8a3a10'};
var BG={H1:'#fdf0cc',H2:'#c8eee8',H3:'#e8d8f8',H4:'#c8e8d8',SP:'#fdd8b8'};
var ICL={ALTA:'#1a5fa8',MEDIA:'#7a5a10',BAJA:'#6a6060'};
var ILB={ALTA:'★ Importancia alta',MEDIA:'◆ Importancia media',BAJA:'· Importancia baja'};
var ICS={ALTA:'i-alta',MEDIA:'i-media',BAJA:'i-baja'};

var BLOCK_INFO={
  H1:{title:'Bloque H1 — Imagen Percibida',color:BC.H1,desc:'La imagen percibida del destino de enoturismo es un constructo de <b>segundo orden</b> formado por cinco dimensiones de experiencia del visitante.',hyps:[{id:'H1',lbl:'H1 general',desc:'Imagen percibida = constructo multidimensional (cognitiva + emocional + funcional + hedónica + simbólica).'},{id:'H1a',lbl:'H1a · Cognitiva (PC)',desc:'Cuanto mayor sea la experiencia cognitiva, mejor la imagen percibida.'},{id:'H1b',lbl:'H1b · Emocional (EA)',desc:'Cuanto mayor sea la experiencia emocional positiva, mejor la imagen percibida.'},{id:'H1c',lbl:'H1c · Funcional (BF)',desc:'Cuanto mayor sea la experiencia funcional (conveniencia, eficiencia), mejor la imagen percibida.'},{id:'H1d',lbl:'H1d · Hedónica (HP)',desc:'Cuanto mayor sea la experiencia hedónica (escape, unicidad, placer sensorial), mejor la imagen percibida.'},{id:'H1e',lbl:'H1e · Simbólica (BS)',desc:'Cuanto mayor sea la experiencia simbólica (prestigio, identidad, estatus), mejor la imagen percibida.'}],scales:'PC (5) · EA (5) · BF (5) · HP (5) · BS (5)',note:'Gap teórico: no existe escala validada de imagen multidimensional específica para enoturismo (Sekhniashvili, 2021).'},
  H2:{title:'Bloque H2 — Confianza del Visitante',color:BC.H2,desc:'La confianza del visitante es un constructo de <b>segundo orden</b> basado en el modelo ABC de Mayer et al. (1995).',hyps:[{id:'H2',lbl:'H2 general',desc:'Confianza = honestidad (TH) + benevolencia (TB) + competencia (TC).'},{id:'H2a',lbl:'H2a · Honestidad (TH)',desc:'A mayor percepción de honestidad (transparencia, sinceridad), mayor confianza.'},{id:'H2b',lbl:'H2b · Benevolencia (TB)',desc:'A mayor percepción de benevolencia (cuidado del bienestar), mayor confianza.'},{id:'H2c',lbl:'H2c · Competencia (TC)',desc:'A mayor percepción de competencia (cultura vitivinícola, capacidad), mayor confianza.'}],scales:'TH (4) · TB (4) · TC (4)',note:'Gap teórico: ningún estudio valida TH+TB+TC específicamente en enoturismo.'},
  H3:{title:'Bloque H3 — Imagen → Confianza (Moderada)',color:BC.H3,desc:'Una mejor imagen del destino se asocia positivamente con mayor confianza. Relación <b>moderada</b> por FP y PP.',hyps:[{id:'H3',lbl:'H3 — Relación principal',desc:'Imagen percibida → Confianza del visitante (relación positiva directa).'},{id:'H3a',lbl:'H3a · Moderador FP',desc:'La familiaridad percibida modera imagen → confianza. Efecto a priori indeterminado.'},{id:'H3b',lbl:'H3b · Moderador PP',desc:'La reputación percibida modera imagen → confianza. Efecto a priori indeterminado.'}],scales:'FP (5) · PP (5)',note:'La confianza actúa como catalizador: lleva la fuerza de la imagen hacia la satisfacción.'},
  H4:{title:'Bloque H4 — Confianza → Satisfacción (Moderada)',color:BC.H4,desc:'La confianza influye positivamente en la satisfacción (variable dependiente final). Relación <b>moderada</b> por CAL y RP.',hyps:[{id:'H4',lbl:'H4 — Relación principal',desc:'Confianza del visitante → Satisfacción percibida (relación positiva directa).'},{id:'H4a',lbl:'H4a · Moderador CAL',desc:'La calidad percibida modera confianza → satisfacción. Efecto a priori indeterminado.'},{id:'H4b',lbl:'H4b · Moderador RP',desc:'La lealtad del enoturista modera confianza → satisfacción. Efecto a priori indeterminado.'}],scales:'CAL (5) · RP (5) · SP (5)',note:'Bianchi (2015): confianza NO predice lealtad directamente — mediada por satisfacción. Valida SP como variable final.'},
};

// Hypothesis nodes — OVALS
// Layout: world is ~2700 wide × 1150 tall
// Key separation: PP (H3-mod, right) ≠ H2a (H2-sub, left); CAL (H4-mod, left) ≠ H2c (H2-sub, right)
// Solution: push H3 moderators LEFT and UP; H4 moderators RIGHT and UP; H2 subs go lower
var HN=[
  {id:'H1', lbl:['Imagen','Percibida'],   x:590, y:570, r:56,c:BC.H1,bg:BG.H1,t:'main'},
  {id:'H1a',lbl:['Cognitiva','(PC)'],      x:275, y:265, r:36,c:BC.H1,bg:BG.H1,t:'sub'},
  {id:'H1b',lbl:['Emocional','(EA)'],      x:165, y:518, r:36,c:BC.H1,bg:BG.H1,t:'sub'},
  {id:'H1c',lbl:['Funcional','(BF)'],      x:192, y:800, r:36,c:BC.H1,bg:BG.H1,t:'sub'},
  {id:'H1d',lbl:['Hedónica','(HP)'],       x:375, y:935, r:36,c:BC.H1,bg:BG.H1,t:'sub'},
  {id:'H1e',lbl:['Simbólica','(BS)'],      x:590, y:985, r:36,c:BC.H1,bg:BG.H1,t:'sub'},
  {id:'H2', lbl:['Confianza'],             x:1490,y:570, r:56,c:BC.H2,bg:BG.H2,t:'main'},
  {id:'H2a',lbl:['Honestidad','(TH)'],     x:1230,y:360, r:36,c:BC.H2,bg:BG.H2,t:'sub'},  // moved down/left
  {id:'H2b',lbl:['Benevolencia','(TB)'],   x:1490,y:215, r:36,c:BC.H2,bg:BG.H2,t:'sub'},
  {id:'H2c',lbl:['Competencia','(TC)'],    x:1750,y:360, r:36,c:BC.H2,bg:BG.H2,t:'sub'},  // moved down/right
  {id:'H3', lbl:['Imagen →','Confianza'],  x:1040,y:455, r:44,c:BC.H3,bg:BG.H3,t:'rel'},
  {id:'FP', lbl:['Familiaridad','(FP)'],   x:855, y:260, r:32,c:BC.H3,bg:BG.H3,t:'mod'},  // left-of-H3, high
  {id:'PP', lbl:['Reputación','(PP)'],     x:1000,y:185, r:32,c:BC.H3,bg:BG.H3,t:'mod'},  // above H3, well away from H2a
  {id:'H3a',lbl:['H3a'],                   x:855, y:700, r:26,c:BC.H3,bg:BG.H3,t:'sub'},
  {id:'H3b',lbl:['H3b'],                   x:1145,y:700, r:26,c:BC.H3,bg:BG.H3,t:'sub'},
