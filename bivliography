// Collision resolution — push overlapping article nodes apart (runs once at load)
(function(){
  var MIN_D=50*2+16; // 2*AR + gap
  for(var ci=0;ci<120;ci++){
    var anyMoved=false;
    for(var ai=0;ai<arts.length;ai++){
      for(var aj=ai+1;aj<arts.length;aj++){
        var ddx=arts[aj].x-arts[ai].x, ddy=arts[aj].y-arts[ai].y;
        var dd2=ddx*ddx+ddy*ddy;
        if(dd2>0 && dd2<MIN_D*MIN_D){
          var dd=Math.sqrt(dd2), push=(MIN_D-dd)*0.5;
          var nx=ddx/dd*push, ny=ddy/dd*push;
          arts[ai].x-=nx; arts[ai].y-=ny;
          arts[aj].x+=nx; arts[aj].y+=ny;
          anyMoved=true;
        }
      }
    }
    if(!anyMoved)break;
  }
})();

