}

function updateModalRevBtn(a){
  var btn=document.getElementById('m-rev-btn');
  var isRev=reviewed.has(a.id);
  if(isRev){
    btn.textContent='↺ Desmarcar revisado';
    btn.style.color='#6a5a40';btn.style.borderColor='#c8bfa8';btn.style.background='#f5f0e5';
  } else {
    btn.textContent='✓ Marcar como revisado';
    btn.style.color='#1a6e3a';btn.style.borderColor='#a8d8b8';btn.style.background='#eef8f1';
  }
}

window.toggleReviewedFromModal=function(){
  if(!modalArt)return;
  toggleReview(modalArt.id);
  updateModalRevBtn(modalArt);
  if(bpanelAH)openBPanel(bpanelAH);
  draw();
};

function closeModal(){document.getElementById('overlay').classList.remove('show');modalArt=null;selectedArt=null;draw();}
window.closeModal=closeModal;
window.handleOverlayClick=function(e){if(e.target===document.getElementById('overlay'))closeModal();};
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeModal();});

function handleClick(mx,my){
  var AR=40;
  for(var i=arts.length-1;i>=0;i--){
    var a=arts[i];if(!isVis(a))continue;
    var dx=mx-wx(a.x),dy=my-wy(a.y),rr=sr(AR);
    if(dx*dx+dy*dy<rr*rr){
      selectedArt=a;
      toggleReview(a.id);
      if(bpanelAH)openBPanel(bpanelAH);
      openModal(a);draw();return;
    }
  }
  selectedArt=null;draw();
}

function updateHover(mx,my){
  var prevA=hoveredArt,prevH=hoveredHN;
  hoveredArt=null;hoveredHN=null;
  // Check HN first (on top)
  hoveredHN=hitHN(mx,my);
  if(!hoveredHN){
    for(var i=arts.length-1;i>=0;i--){
      var a=arts[i];if(!isVis(a))continue;
      var dx=mx-wx(a.x),dy=my-wy(a.y),rr=sr(AR+6);
      if(dx*dx+dy*dy<rr*rr){hoveredArt=a;break;}
    }
  }
  if(hoveredArt!==prevA||hoveredHN!==prevH)draw();
  var hl=document.getElementById('hlabel');
  if(hoveredHN){
    hl.textContent=hoveredHN.lbl.join(' ')+' — clic · seleccionar, arrastrar · mover';
    var tx=Math.min(mx+14,W-300),ty=Math.max(50,my-28);
    hl.style.left=tx+'px';hl.style.top=ty+'px';hl.style.display='block';
  } else if(hoveredArt){
    var isRev=reviewed.has(hoveredArt.id);
    hl.textContent=hoveredArt.autor+' ('+hoveredArt.año+')'+(isRev?' ✓':'')+' — clic · detalle, arrastrar · mover';
    var tx2=Math.min(mx+14,W-300),ty2=Math.max(50,my-28);
    hl.style.left=tx2+'px';hl.style.top=ty2+'px';hl.style.display='block';
  } else hl.style.display='none';
}

// DRAW
function draw(){
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#f4f0e8';ctx.fillRect(0,0,W,H);
  // Grid
  if(SC>0.18){
    var gs=60*SC,ox=((TX%gs)+gs)%gs,oy=((TY%gs)+gs)%gs;
    ctx.strokeStyle='rgba(0,0,0,.032)';ctx.lineWidth=0.5;
    for(var gx=ox;gx<W;gx+=gs){ctx.beginPath();ctx.moveTo(gx,0);ctx.lineTo(gx,H);ctx.stroke();}
    for(var gy=oy;gy<H;gy+=gs){ctx.beginPath();ctx.moveTo(0,gy);ctx.lineTo(W,gy);ctx.stroke();}
  }
  // Helper: is this HN id "active" (selected or hovered)?
  var actHN=selectedHN||hoveredHN;
  // Which HN ids are "lit" (connected to the active one)?
  var litIds={};
  if(actHN){
    litIds[actHN.id]=true;
    // sub-link connections — mark the other end
    var subDef=[['H1a','H1'],['H1b','H1'],['H1c','H1'],['H1d','H1'],['H1e','H1'],['H2a','H2'],['H2b','H2'],['H2c','H2'],['FP','H3'],['PP','H3'],['H3a','H3'],['H3b','H3'],['CAL','H4'],['RP','H4'],['H4a','H4'],['H4b','H4']];
    subDef.forEach(function(sl){if(sl[0]===actHN.id||sl[1]===actHN.id){litIds[sl[0]]=true;litIds[sl[1]]=true;}});
    // flow connections
    var flowDef=[['H1','H3'],['H3','H2'],['H2','H4'],['H4','SP']];
    flowDef.forEach(function(fl){if(fl[0]===actHN.id||fl[1]===actHN.id){litIds[fl[0]]=true;litIds[fl[1]]=true;}});
  }

  // Sub-links dashed
  var subL=[['H1a','H1'],['H1b','H1'],['H1c','H1'],['H1d','H1'],['H1e','H1'],['H2a','H2'],['H2b','H2'],['H2c','H2'],['FP','H3'],['PP','H3'],['H3a','H3'],['H3b','H3'],['CAL','H4'],['RP','H4'],['H4a','H4'],['H4b','H4']];
  subL.forEach(function(sl){
    var na=hMap[sl[0]],nb=hMap[sl[1]],col=BC[hBlock(sl[1])]||'#888';
    var isLit=actHN&&(litIds[sl[0]]&&litIds[sl[1]]);
    var op=isLit?0.85:actHN?0.08:0.25;
    var lw=isLit?2.8:1;
    ctx.save();
    if(!isLit)ctx.setLineDash([5*SC,3.5*SC]);
    ctx.strokeStyle=ha(col,op);ctx.lineWidth=lw*SC;
    ctx.beginPath();ctx.moveTo(wx(na.x),wy(na.y));ctx.lineTo(wx(nb.x),wy(nb.y));ctx.stroke();
    ctx.restore();
    // Arrowhead on lit sub-links
    if(isLit){
      var x1=wx(na.x),y1=wy(na.y),x2=wx(nb.x),y2=wy(nb.y);
      var dx=x2-x1,dy=y2-y1,len=Math.sqrt(dx*dx+dy*dy);
      if(len>0){var ux=dx/len,uy=dy/len,ex=x2-ux*sr(nb.r*ovalRx(nb)),ey=y2-uy*sr(nb.r);
        var ah=6*SC,ab=3*SC;ctx.fillStyle=ha(col,0.75);
        ctx.beginPath();ctx.moveTo(ex+ux*ah,ey+uy*ah);ctx.lineTo(ex-uy*ab,ey+ux*ab);ctx.lineTo(ex+uy*ab,ey-ux*ab);ctx.closePath();ctx.fill();}
    }
  });

  // Main flow arrows
  var flows=[['H1','H3',BC.H3],['H3','H2',BC.H3],['H2','H4',BC.H4],['H4','SP',BC.SP]];
  flows.forEach(function(fl){
    var na=hMap[fl[0]],nb=hMap[fl[1]],col=fl[2];
    var isLit=actHN&&(litIds[fl[0]]&&litIds[fl[1]]);
    var nary=sr(na.r),narx=nary*ovalRx(na),nbry=sr(nb.r),nbrx=nbry*ovalRx(nb);
    var x1=wx(na.x)+narx,y1=wy(na.y),x2=wx(nb.x)-nbrx,y2=wy(nb.y);
    var op=isLit?0.95:actHN?0.12:0.6;
    var lw=isLit?4.5:2.8;
    ctx.strokeStyle=ha(col,op);ctx.lineWidth=lw*SC;
    ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();
    var dx=x2-x1,dy=y2-y1,len=Math.sqrt(dx*dx+dy*dy),ux=dx/len,uy=dy/len;
    var ah=(isLit?11:8)*SC,ab=(isLit?5.5:4)*SC;
    ctx.fillStyle=ha(col,isLit?1:0.8);
    ctx.beginPath();ctx.moveTo(x2+ux*ah,y2+uy*ah);ctx.lineTo(x2-uy*ab,y2+ux*ab);ctx.lineTo(x2+uy*ab,y2-ux*ab);ctx.closePath();ctx.fill();
  });
  // Article connection lines
  arts.forEach(function(a){
    if(!isVis(a))return;
    var isSel=selectedArt&&selectedArt.id===a.id;
    var isHov=hoveredArt&&hoveredArt.id===a.id;
    var isRev=reviewed.has(a.id);
    var artConnectedToHN=actHN&&a.hips.some(function(h){return litIds[h]||h===actHN.id;});
    a.hips.forEach(function(h){
      var th=hMap[h];if(!th)return;
      var col=BC[hBlock(h)]||BC[h]||'#888';
      var isPrim=a.prim.indexOf(h)>=0;
      var op,lw;
      if(isSel){op=isPrim?0.82:0.52;lw=isPrim?4.5:2.8;}
      else if(isHov){op=isPrim?0.62:0.32;lw=isPrim?3.5:2.0;}
      else if(actHN){
        if(artConnectedToHN){op=isPrim?0.52:0.22;lw=isPrim?2.4:1.2;}
        else{op=0.03;lw=0.4;}
      }
      else if(selectedArt){op=0.03;lw=0.4;}
      else if(isRev){op=isPrim?0.12:0.05;lw=isPrim?0.8:0.4;}
      else{op=isPrim?0.2:0.07;lw=isPrim?1.3:0.6;}
      ctx.strokeStyle=ha(col,op);ctx.lineWidth=lw*SC;
      var x1=wx(a.x),y1=wy(a.y),x2=wx(th.x),y2=wy(th.y);
      ctx.beginPath();ctx.moveTo(x1,y1);ctx.bezierCurveTo(x1+(x2-x1)*.45,y1,x1+(x2-x1)*.55,y2,x2,y2);ctx.stroke();
      if(isSel&&!isPrim){
        var dx=x2-x1,dy=y2-y1,len=Math.sqrt(dx*dx+dy*dy);
        if(len>0){var ux=dx/len,uy=dy/len,ex=x2-ux*sr(th.r+8),ey=y2-uy*sr(th.r+8);
          var ah=6*SC,ab=3*SC;ctx.fillStyle=ha(col,0.65);
          ctx.beginPath();ctx.moveTo(ex+ux*ah,ey+uy*ah);ctx.lineTo(ex-uy*ab,ey+ux*ab);ctx.lineTo(ex+uy*ab,ey-ux*ab);ctx.closePath();ctx.fill();}
      }
    });
  });

  // ── HYPOTHESIS NODES — OVALS ──
  HN.forEach(function(n){
    var x=wx(n.x),y=wy(n.y),ry=sr(n.r),rx=ry*ovalRx(n);
    var isSN=selectedHN&&selectedHN.id===n.id;
    var isHN=hoveredHN&&hoveredHN.id===n.id;
    var isLitN=actHN&&litIds[n.id];
    // Glow
    if(n.t==='main'||n.t==='out'){ctx.shadowColor=ha(n.c,isSN?0.45:0.22);ctx.shadowBlur=(isSN?38:24)*SC;}
    if(isSN){ctx.shadowColor=ha(n.c,0.5);ctx.shadowBlur=40*SC;}
    // Fill — brighter when selected
    ctx.fillStyle=isSN?ha(n.c,0.28):isHN?ha(n.c,0.2):actHN&&!isLitN?ha(n.bg||'#fff',0.5):n.bg||'#fff';
    ctx.strokeStyle=n.c;
    var baseW=(n.t==='main'||n.t==='out'?3:n.t==='rel'?2.2:1.8);
    ctx.lineWidth=(isSN?baseW*2.2:isHN?baseW*1.6:actHN&&!isLitN?baseW*0.5:baseW)*SC;
    ctx.globalAlpha=actHN&&!isLitN?0.28:1;
    if(n.t==='mod'){ctx.save();ctx.setLineDash([5*SC,2.5*SC]);}
    ctx.beginPath();ctx.ellipse(x,y,rx,ry,0,0,Math.PI*2);ctx.fill();ctx.stroke();
    if(n.t==='mod')ctx.restore();
    ctx.shadowBlur=0;ctx.globalAlpha=1;
    // Outer ring for main/out + selected
    if(n.t==='main'||n.t==='out'){
      ctx.strokeStyle=ha(n.c,isSN?0.6:0.28);ctx.lineWidth=(isSN?1.8:0.9)*SC;
      ctx.beginPath();ctx.ellipse(x,y,rx+9*SC,ry+9*SC,0,0,Math.PI*2);ctx.stroke();
    }
    if(isSN){
      // Second outer ring for selected state
      ctx.strokeStyle=ha(n.c,0.35);ctx.lineWidth=0.8*SC;
      ctx.setLineDash([6*SC,3*SC]);
      ctx.beginPath();ctx.ellipse(x,y,rx+16*SC,ry+16*SC,0,0,Math.PI*2);ctx.stroke();
      ctx.setLineDash([]);
    }
    // Article count badge
    var cnt=hCount[n.id];
    if(cnt>0&&SC>0.25&&n.t!=='out'){
      var br=11*SC,bx=x+rx*0.8,by=y-ry*0.82;
      ctx.fillStyle=n.c;ctx.beginPath();ctx.arc(bx,by,br,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#fff';ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.font='600 '+(8*SC)+'px Georgia';ctx.fillText(cnt,bx,by);
    }
    // Label — big and bold so the model dominates visually
    var fs=n.t==='main'||n.t==='out'?25:n.t==='rel'?21:17;
    var fw='700';
    ctx.fillStyle=n.c;ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.font=fw+' '+(fs*SC)+'px Georgia';
    var lh=(fs+4.5)*SC,yo=-(n.lbl.length-1)*lh/2;
    n.lbl.forEach(function(l,i){ctx.fillText(l,x,y+yo+i*lh);});
  });

  // ── ARTICLE NODES — CIRCLES ──
  arts.forEach(function(a){
    var vis=isVis(a),isSel=selectedArt&&selectedArt.id===a.id,isHov=hoveredArt&&hoveredArt.id===a.id;
    var isRev=reviewed.has(a.id);
    var x=wx(a.x),y=wy(a.y),r=sr(AR);
    var fadedBySearch=!vis;
    var fadedBySel=selectedArt&&!isSel&&!isHov;
    var artConnectedToHN2=actHN&&a.hips.some(function(h){return litIds[h]||h===actHN.id;});
    var fadedByHN=actHN&&!artConnectedToHN2&&!isSel&&!isHov;
    ctx.globalAlpha=fadedBySearch?0.04:fadedBySel||fadedByHN?0.13:1;
    // Multi outer ring
    if(a.multi){
      ctx.save();ctx.setLineDash([4*SC,2.5*SC]);
      ctx.strokeStyle=ha('#7a5a10',isSel?0.9:isRev?0.25:0.45);ctx.lineWidth=(isSel?1.5:0.8)*SC;
      ctx.beginPath();ctx.arc(x,y,r+6*SC,0,Math.PI*2);ctx.stroke();ctx.restore();
    }
    // Color accent arc
    var acol=BC[hBlock(a.pH)]||'#888';
    var arc2=2*Math.PI*(r+4*SC);
    ctx.save();ctx.setLineDash([arc2*0.38,arc2*0.62]);
    ctx.strokeStyle=ha(acol,isRev?0.25:isSel?0.9:0.55);ctx.lineWidth=(isSel?1.8:1.3)*SC;
    ctx.beginPath();ctx.arc(x,y,r+4*SC,-Math.PI/2,Math.PI*2*1.5);ctx.stroke();ctx.restore();
    // Fill
    ctx.fillStyle=isRev?'#dcd8d0':isSel?'#fffcf5':'#fff';
    ctx.strokeStyle=isRev?ha(ICL[a.imp]||'#888',0.45):ICL[a.imp]||'#888';
    ctx.lineWidth=(isSel?3.2:a.multi?2.4:1.8)*SC;
    ctx.shadowColor=isSel?'rgba(0,0,0,.16)':'rgba(0,0,0,.07)';ctx.shadowBlur=(isSel?14:5)*SC;
    ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.fill();ctx.stroke();ctx.shadowBlur=0;
    // Hover ring
    if(isHov&&!isSel){ctx.strokeStyle=ha('#7a5a10',0.32);ctx.lineWidth=SC*0.8;ctx.beginPath();ctx.arc(x,y,r+9*SC,0,Math.PI*2);ctx.stroke();}
    // Labels
    if(SC>0.12){
      ctx.textAlign='center';ctx.textBaseline='middle';
      var at=a.autor.split(' et al.')[0].split(' &')[0].split(',')[0].trim();
      if(at.length>13)at=at.slice(0,12)+'…';
      ctx.fillStyle=isRev?'rgba(80,70,60,.6)':isSel?'#1a1814':'#2a2018';
      ctx.font=(isSel?'700':'600')+' '+(15*SC)+'px Georgia';
      ctx.fillText(at,x,y-10*SC);
      ctx.fillStyle=isRev?ha(ICL[a.imp]||'#888',0.5):ICL[a.imp]||'#888';
      ctx.font='700 '+(18*SC)+'px Georgia';
      ctx.fillText(a.año,x,y+10*SC);
      if(SC>0.22){
        var ht=a.hips.slice(0,3).join('·')+(a.hips.length>3?'…':'');
        ctx.fillStyle=isRev?'rgba(90,75,55,.4)':'rgba(90,75,55,.85)';ctx.font=(11*SC)+'px Georgia';
        ctx.fillText(ht,x,y+27*SC);
      }
      if(a.multi){ctx.fillStyle=isRev?ha('#8a6a20',0.4):'#8a6a20';ctx.font=(13*SC)+'px Georgia';ctx.fillText('⚡',x+r-4*SC,y-r+10*SC);}
      // Reviewed checkmark
      if(isRev&&SC>0.18){ctx.fillStyle='rgba(42,138,74,.75)';ctx.font='700 '+(14*SC)+'px Georgia';ctx.fillText('✓',x-r+7*SC,y-r+12*SC);}
    }
    ctx.globalAlpha=1;
  });
}
draw();updateRevCounter();

