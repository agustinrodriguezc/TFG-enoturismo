    var isRev=reviewed.has(a.id);
    body+='<div class="bitem '+cls+(isRev?' reviewed':'')+'"><b>'+a.autor+' ('+a.año+')</b><br><span style="font-size:9px;color:#6a5a40">'+a.met+'</span>'+(isRev?' <span style="color:#2a8a4a;font-size:9px">✓</span>':'')+'</div>';
  });
  body+='<div class="bsec">Nota teórica</div><div class="bval" style="font-style:italic;color:#6a5a40">'+info.note+'</div>';
  document.getElementById('bp-body').innerHTML=body;
  document.getElementById('bp-body').scrollTop=0;
  document.getElementById('bpanel').classList.add('open');
}
function closeBPanel(){document.getElementById('bpanel').classList.remove('open');bpanelAH=null;}
window.closeBPanel=closeBPanel;

